{
  "name": "@openturn/example-splendor-app",
  "private": true,
  "type": "module",
  "openturn": {
    "runtime": "browser"
  },
  "scripts": {
    "build": "bun run ../../../../packages/cli/src/index.ts build .",
    "deploy": "bun run ../../../../packages/cli/src/index.ts deploy . --project splendor --name \"Splendor\"",
    "dev": "bun run ../../../../packages/cli/src/index.ts dev . --port 3008",
    "typecheck": "bun x tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@openturn/example-splendor-bots": "workspace:*",
    "@openturn/example-splendor-game": "workspace:*",
    "@openturn/lobby": "workspace:*",
    "@openturn/react": "workspace:*",
    "@openturn/server": "workspace:*",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.0.0",
    "typescript": "^6.0.2"
  }
}
