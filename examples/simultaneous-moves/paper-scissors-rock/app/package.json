{
  "name": "@openturn/example-paper-scissors-rock-app",
  "private": true,
  "type": "module",
  "openturn": {
    "runtime": "browser"
  },
  "scripts": {
    "dev": "bun run ../../../../packages/cli/src/index.ts dev . --port 3003",
