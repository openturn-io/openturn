{
  "name": "@openturn/cli",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "openturn": "./src/index.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "openturn": {
    "runtime": "bun"
  },
  "scripts": {
    "dev": "cd ../.. && bun run packages/cli/src/index.ts dev \"$@\"",
    "test": "bun test",
    "typecheck": "bun x tsc -p tsconfig.json --pretty false",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@openturn/bridge": "workspace:*",
    "@openturn/core": "workspace:*",
    "@openturn/deploy": "workspace:*",
    "@openturn/inspector-ui": "workspace:*",
    "@openturn/json": "workspace:*",
    "@openturn/protocol": "workspace:*",
    "@openturn/react": "workspace:*",
    "@openturn/server": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "better-auth": "^1.6.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "beta",
    "posthog-node": "^5.30.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openturn-io/openturn.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/openturn-io/openturn/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/openturn-io/openturn/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "bin": {
      "openturn": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ]
}
