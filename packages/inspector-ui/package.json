{
  "name": "@openturn/inspector-ui",
  "version": "0.4.0",
  "type": "module",
  "openturn": {
    "runtime": "browser"
  },
  "exports": {
    ".": "./src/index.tsx"
  },
  "types": "./src/index.tsx",
  "scripts": {
    "test": "vitest run",
    "typecheck": "bun x tsc -p tsconfig.json --pretty false",
    "build": "vite build -c vite.build.config.ts",
    "prepublishOnly": "bun run build",
    "prepack": "node ../../scripts/prepack.mjs"
  },
  "dependencies": {
    "@openturn/bridge": "^0.4.0",
    "@openturn/core": "^0.4.0",
    "@openturn/inspector": "^0.4.0",
    "@openturn/react": "^0.4.0",
    "@openturn/replay": "^0.4.0",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "re-resizable": "^6.11.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/react": "^16.3.0",
    "@types/dagre": "^0.7.54",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "jsdom": "^28.1.0",
    "shadcn": "^4.2.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openturn-io/openturn.git",
    "directory": "packages/inspector-ui"
  },
  "homepage": "https://github.com/openturn-io/openturn/tree/main/packages/inspector-ui#readme",
  "bugs": {
    "url": "https://github.com/openturn-io/openturn/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ]
}
