{
  "name": "@openturn/react",
  "version": "0.3.0",
  "type": "module",
  "openturn": {
    "runtime": "browser"
  },
  "exports": {
    ".": "./src/index.tsx"
  },
  "types": "./src/index.tsx",
  "scripts": {
    "test": "vitest run",
    "typecheck": "bun x tsc -p tsconfig.json --pretty false",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "@openturn/bot": "^0.3.0",
    "@openturn/bridge": "^0.3.0",
    "@openturn/client": "^0.3.0",
    "@openturn/core": "^0.3.0",
    "@openturn/inspector": "^0.3.0",
    "@openturn/lobby": "^0.3.0",
    "@openturn/protocol": "^0.3.0",
    "@openturn/replay": "^0.3.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "devDependencies": {
    "@openturn/gamekit": "^0.3.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "jsdom": "^28.1.0",
    "vitest": "^3.2.4"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openturn-io/openturn.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/openturn-io/openturn/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/openturn-io/openturn/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ]
}
