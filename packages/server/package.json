{
  "name": "@openturn/server",
  "version": "0.3.0",
  "type": "module",
  "openturn": {
    "runtime": "worker"
  },
  "exports": {
    ".": "./src/index.ts",
    "./worker": "./src/worker.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "test": "bun test",
    "typecheck": "bun x tsc -p tsconfig.json --pretty false",
    "build": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build",
    "prepack": "node ../../scripts/prepack.mjs",
    "postpack": "node ../../scripts/postpack.mjs"
  },
  "dependencies": {
    "@openturn/bot": "^0.3.0",
    "@openturn/core": "^0.3.0",
    "@openturn/json": "^0.3.0",
    "@openturn/protocol": "^0.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260417.1",
    "@openturn/gamekit": "^0.3.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openturn-io/openturn.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/openturn-io/openturn/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/openturn-io/openturn/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./worker": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ]
}
